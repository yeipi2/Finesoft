          "name": "Projects paginated",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/{{apiVersion}}/projects?page=1&pageSize=5&search={{searchTerm}}&sort=name" },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Status 200/401/403', function () { pm.expect([200,401,403]).to.include(pm.response.code); });", "if (pm.response.code===200){ var j=pm.response.json(); ['items','total','page','pageSize','pages','hasNext','hasPrev'].forEach(function(k){ pm.expect(j).to.have.property(k); }); }" ] } }]
        },
        {
          "name": "Employees paginated",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/{{apiVersion}}/employees?page=1&pageSize=5&search={{searchTerm}}&sort=fullName" },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Status 200/401/403', function () { pm.expect([200,401,403]).to.include(pm.response.code); });", "if (pm.response.code===200){ var j=pm.response.json(); ['items','total','page','pageSize','pages','hasNext','hasPrev'].forEach(function(k){ pm.expect(j).to.have.property(k); }); }" ] } }]
        },
        {
          "name": "Tickets paginated",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/{{apiVersion}}/tickets?page=1&pageSize=5&search={{searchTerm}}&sort=-createdAt" },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Status 200/401/403', function () { pm.expect([200,401,403]).to.include(pm.response.code); });", "if (pm.response.code===200){ var j=pm.response.json(); ['items','total','page','pageSize','pages','hasNext','hasPrev'].forEach(function(k){ pm.expect(j).to.have.property(k); }); }" ] } }]
        },
        {
          "name": "Quotes paginated",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/{{apiVersion}}/quotes?page=1&pageSize=5&search={{searchTerm}}&sort=-createdAt" },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Status 200/401/403', function () { pm.expect([200,401,403]).to.include(pm.response.code); });", "if (pm.response.code===200){ var j=pm.response.json(); ['items','total','page','pageSize','pages','hasNext','hasPrev'].forEach(function(k){ pm.expect(j).to.have.property(k); }); }" ] } }]
        },
        {
          "name": "Invoices paginated",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/{{apiVersion}}/invoices?page=1&pageSize=5&search={{searchTerm}}&sort=-invoiceDate" },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Status 200/401/403', function () { pm.expect([200,401,403]).to.include(pm.response.code); });", "if (pm.response.code===200){ var j=pm.response.json(); ['items','total','page','pageSize','pages','hasNext','hasPrev'].forEach(function(k){ pm.expect(j).to.have.property(k); }); }" ] } }]
        }
      ]
    },
    {
      "name": "05 - Error Contract (ProblemDetails)",
      "item": [
        {
          "name": "401 protected endpoint without token",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": "{{baseUrl}}/api/{{apiVersion}}/users?page=1&pageSize=1"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 401', function () { pm.response.to.have.status(401); });",
                  "var j = pm.response.json();",
                  "pm.test('ProblemDetails shape', function(){ ['title','status','type'].forEach(function(k){ pm.expect(j).to.have.property(k); }); });"
                ]
              }
            }
          ]
        },
        {
          "name": "404 user not found",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/{{apiVersion}}/users/{{notFoundUserId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 404/403', function () { pm.expect([404,403]).to.include(pm.response.code); });",
                  "if (pm.response.code === 404) {",
                  "  var j = pm.response.json();",
                  "  pm.test('ProblemDetails shape', function(){ ['title','status','type','detail'].forEach(function(k){ pm.expect(j).to.have.property(k); }); });",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "422 invalid public quote status",
          "request": {
            "auth": { "type": "noauth" },
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"INVALID\"\n}"
            },
            "url": "{{baseUrl}}/api/{{apiVersion}}/quotes/public/{{publicToken}}/status"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 422/404', function () { pm.expect([422,404]).to.include(pm.response.code); });",
                  "if (pm.response.code === 422) {",
                  "  var j = pm.response.json();",
                  "  pm.test('ValidationProblemDetails shape', function(){ ['title','status','type','errors'].forEach(function(k){ pm.expect(j).to.have.property(k); }); });",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
