@* fs-front/Components/Clients/Form/AccessDataSection.razor *@
@using fs_front.DTO
@using fs_front.Components.Shared
@using fs_front.Services
@inject IUserApiService UserApiService

<FormSection Title="Datos de Acceso al Sistema"
             IconClass="bi-lock"
             IsComplete="@IsComplete">
    <div class="row g-3">

        <div class="col-md-6">
            <label for="Email" class="form-label small fw-bold">
                Email / Usuario <span class="text-danger">*</span>
            </label>
            <div class="input-group input-group-sm">
                <InputText id="Email"
                           type="email"
                           class="@GetEmailCssClass()"
                           placeholder="correo@empresa.com"
                           @bind-Value="Model.Email"
                           @bind-Value:after="OnEmailChanged" />
                @if (_emailChecking)
                {
                    <span class="input-group-text bg-white">
                        <span class="spinner-border spinner-border-sm text-warning" title="Verificando..."></span>
                    </span>
                }
                else if (_emailAvailable == true && !string.IsNullOrWhiteSpace(Model.Email))
                {
                    <span class="input-group-text bg-white text-success">
                        <i class="bi bi-check-circle-fill"></i>
                    </span>
                }
            </div>
            <small class="text-muted">Este será el usuario de acceso al sistema</small>
            @if (_emailAvailable == false)
            {
                <div class="text-danger small mt-1">
                    <i class="bi bi-exclamation-circle me-1"></i>Este correo ya está registrado en el sistema
                </div>
            }
            else if (ValidationErrors.ContainsKey("Email"))
            {
                <div class="text-danger small mt-1">
                    <i class="bi bi-exclamation-circle me-1"></i>@ValidationErrors["Email"]
                </div>
            }
        </div>

        <div class="col-md-6">
            <label for="Password" class="form-label small fw-bold">
                Contraseña <span class="text-danger">*</span>
            </label>
            <div class="input-group input-group-sm">
                <InputText id="Password"
                           type="@(ShowPassword ? "text" : "password")"
                           class="form-control"
                           placeholder="Mínimo 8 caracteres"
                           @bind-Value="Model.Password"
                           @oninput="OnPasswordInput" />
                <button class="btn btn-outline-secondary"
                        type="button"
                        @onclick="TogglePasswordVisibility"
                        tabindex="-1">
                    <i class="bi @(ShowPassword ? "bi-eye-slash" : "bi-eye")"></i>
                </button>
            </div>
            <small class="text-muted d-block mt-1">
                Debe contener: mínimo 8 caracteres, una mayúscula, una minúscula, un número y un carácter especial
            </small>
            @if (ValidationErrors.ContainsKey("Password"))
            {
                <div class="text-danger small mt-1">
                    <i class="bi bi-exclamation-circle me-1"></i>@ValidationErrors["Password"]
                </div>
            }
        </div>

    </div>
</FormSection>

@code {
    [Parameter] public ClientDto Model { get; set; } = new();
    [Parameter] public Dictionary<string, string> ValidationErrors { get; set; } = new();
    [Parameter] public bool IsComplete { get; set; }
    [Parameter] public Action? OnValidate { get; set; }
    [Parameter] public EventCallback<ChangeEventArgs> OnPasswordInput { get; set; }

    private bool ShowPassword { get; set; }
    private bool _emailChecking = false;
    private bool? _emailAvailable = null;
    private string _lastCheckedEmail = "";
    private CancellationTokenSource? _debounce;

    private void TogglePasswordVisibility() => ShowPassword = !ShowPassword;

    private string GetEmailCssClass()
    {
        var baseClass = "form-control form-control-sm";
        if (_emailChecking) return $"{baseClass} border-warning";
        if (_emailAvailable == false) return $"{baseClass} border-danger is-invalid";
        if (_emailAvailable == true && !string.IsNullOrWhiteSpace(Model.Email))
            return $"{baseClass} border-success";
        return baseClass;
    }

    private async Task OnEmailChanged()
    {
        var email = (Model.Email ?? "").Trim();

        if (email == _lastCheckedEmail) { NotifyParent(); return; }

        _debounce?.Cancel();
        _debounce = new CancellationTokenSource();
        var token = _debounce.Token;

        _emailAvailable = null;
        ValidationErrors.Remove("Email");

        var formatOk = System.Text.RegularExpressions.Regex.IsMatch(
            email, @"^[^@\s]+@[^@\s]+\.[^@\s]+$");

        if (string.IsNullOrWhiteSpace(email) || !formatOk) { NotifyParent(); return; }

        try
        {
            await Task.Delay(500, token);
            if (token.IsCancellationRequested) return;

            _emailChecking = true;
            StateHasChanged();

            var available = await UserApiService.IsEmailAvailableAsync(email, Model.UserId);

            if (!token.IsCancellationRequested)
            {
                _emailAvailable = available;
                _lastCheckedEmail = email;

                if (!available)
                    ValidationErrors["Email"] = "Este correo ya está registrado en el sistema";
                else
                    ValidationErrors.Remove("Email");
            }
        }
        catch (TaskCanceledException) { }
        catch (Exception ex)
        {
            Console.WriteLine($"Error verificando email: {ex.Message}");
            _emailAvailable = null;
        }
        finally
        {
            _emailChecking = false;
            NotifyParent();
            StateHasChanged();
        }
    }

    private void NotifyParent() => OnValidate?.Invoke();
    public bool IsEmailInvalid => _emailAvailable == false || _emailChecking;
}