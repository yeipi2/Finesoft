@using fs_front.DTO

@if (Invoice?.Status == "Cancelada")
{
    <section class="invd-cancelled mb-4">
        <h6 class="mb-2 d-flex align-items-center gap-2">
            <span class="invd-cancelled__icon"><i class="bi bi-x-circle-fill"></i></span>
            Factura cancelada
        </h6>

        <div class="row g-2">
            @if (Invoice.CancelledDate.HasValue)
            {
                <div class="col-md-4">
                    <small class="invd-cancelled__label">Fecha de cancelación</small>
                    <div class="invd-cancelled__value">@Invoice.CancelledDate.Value.ToString("dd/MM/yyyy")</div>
                </div>
            }
            <div class="col">
                <small class="invd-cancelled__label">Motivo</small>
                <div class="invd-cancelled__value">@(Invoice.CancellationReason ?? "Sin motivo registrado")</div>
            </div>
        </div>
    </section>
}

<style>
    .invd-cancelled {
        border: 1px solid var(--invd-danger-border);
        background: var(--invd-danger-soft);
        border-radius: 12px;
        padding: 0.85rem 1rem;
    }

    .invd-cancelled h6 {
        font-size: 0.95rem;
        color: var(--invd-danger);
        font-weight: 700;
    }

    .invd-cancelled__icon {
        width: 1.55rem;
        height: 1.55rem;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: color-mix(in srgb, var(--invd-danger) 20%, transparent);
        color: var(--invd-danger);
        font-size: 0.78rem;
    }

    .invd-cancelled__label {
        display: block;
        font-size: 0.74rem;
        color: var(--invd-danger);
        text-transform: uppercase;
        letter-spacing: 0.04em;
        margin-bottom: 0.15rem;
    }

    .invd-cancelled__value {
        color: var(--invd-danger-ink);
        font-weight: 600;
        font-size: 0.92rem;
    }
</style>

@code {
    [Parameter] public InvoiceDetailDto? Invoice { get; set; }
}
