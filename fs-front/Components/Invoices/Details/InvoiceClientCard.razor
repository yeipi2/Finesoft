@using fs_front.DTO

<section class="invd-panel">
    <header class="invd-panel__header d-flex justify-content-between align-items-center flex-wrap gap-2">
        <h5 class="mb-0 d-flex align-items-center gap-2">
            <span class="invd-icon-wrap"><i class="bi bi-building"></i></span>
            Información del cliente
        </h5>
        <span class="invd-tag invd-tag--@(Invoice?.InvoiceType == "Monthly" ? "primary" : "secondary")">@Invoice?.InvoiceType</span>
    </header>

    <div class="invd-panel__body">
        <div class="row g-3">
            <div class="col-md-6">
                <div class="invd-field">
                    <span class="invd-field__label">Cliente</span>
                    <span class="invd-field__value">@Invoice?.ClientName</span>
                </div>
                <div class="invd-field">
                    <span class="invd-field__label">Email</span>
                    <span class="invd-field__value">@Invoice?.ClientEmail</span>
                </div>
            </div>
            <div class="col-md-6">
                <div class="invd-field">
                    <span class="invd-field__label">RFC</span>
                    <span class="invd-field__value">@Invoice?.ClientRFC</span>
                </div>
                <div class="invd-field">
                    <span class="invd-field__label">Creado por</span>
                    <span class="invd-field__value">@Invoice?.CreatedByUserName</span>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .invd-panel {
        border: 1px solid var(--invd-border);
        border-radius: 14px;
        background: var(--invd-surface);
    }

    .invd-panel__header {
        padding: 0.85rem 1rem;
        border-bottom: 1px solid var(--invd-border);
    }

    .invd-panel__header h5 {
        font-size: 1rem;
        font-weight: 600;
    }

    .invd-panel__body {
        padding: 1rem;
    }

    .invd-icon-wrap {
        width: 1.7rem;
        height: 1.7rem;
        border-radius: 999px;
        background: var(--invd-primary-soft);
        color: var(--invd-primary);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.85rem;
    }

    .invd-tag {
        border-radius: 999px;
        border: 1px solid var(--invd-border);
        padding: 0.2rem 0.55rem;
        font-size: 0.75rem;
        font-weight: 600;
    }

    .invd-tag--primary {
        background: var(--invd-primary-soft);
        color: var(--invd-primary);
    }

    .invd-tag--secondary {
        background: var(--invd-surface-soft);
        color: var(--invd-muted);
    }

    .invd-field {
        display: flex;
        flex-direction: column;
        gap: 0.15rem;
        padding: 0.55rem 0.6rem;
        border-radius: 10px;
        background: var(--invd-surface-soft);
        border: 1px solid var(--invd-border);
        margin-bottom: 0.5rem;
    }

    .invd-field:last-child {
        margin-bottom: 0;
    }

    .invd-field__label {
        font-size: 0.75rem;
        color: var(--invd-muted);
        text-transform: uppercase;
        letter-spacing: 0.03em;
    }

    .invd-field__value {
        font-size: 0.95rem;
        font-weight: 600;
        color: var(--invd-text);
    }
</style>

@code {
    [Parameter] public InvoiceDetailDto? Invoice { get; set; }
}
