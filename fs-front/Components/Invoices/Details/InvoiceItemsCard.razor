@using fs_front.DTO

<section class="invd-panel">
    <header class="invd-panel__header d-flex justify-content-between align-items-center">
        <h5 class="mb-0 d-flex align-items-center gap-2">
            <span class="invd-icon-wrap"><i class="bi bi-list-ul"></i></span>
            Artículos de la factura
        </h5>
        <span class="invd-count">@(Invoice?.Items.Count ?? 0)</span>
    </header>

    <div class="invd-panel__body">
        <div class="table-responsive">
            <table class="table table-sm align-middle invd-table mb-0">
                <thead>
                    <tr>
                        <th>Descripción</th>
                        <th class="text-center">Cantidad</th>
                        <th class="text-end">Precio Unit.</th>
                        <th class="text-end">Subtotal</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Invoice?.Items ?? new())
                    {
                        <tr>
                            <td>
                                <div class="fw-medium">@item.Description</div>
                                @if (!string.IsNullOrEmpty(item.ServiceName))
                                {
                                    <small class="invd-subline">
                                        <i class="bi bi-gear me-1"></i>@item.ServiceName
                                    </small>
                                }
                                @if (item.TicketId.HasValue && item.TicketId.Value > 0)
                                {
                                    <small class="invd-subline invd-subline--accent d-block">
                                        <i class="bi bi-ticket-perforated me-1"></i>
                                        Ticket #@item.TicketId: @item.TicketTitle
                                    </small>
                                }
                            </td>
                            <td class="text-center">@item.Quantity</td>
                            <td class="text-end">@item.UnitPrice.ToString("C2", new System.Globalization.CultureInfo("en-US"))</td>
                            <td class="text-end fw-semibold">@item.Subtotal.ToString("C2", new System.Globalization.CultureInfo("en-US"))</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="invd-totals mt-3 ms-auto">
            <div class="invd-total-row">
                <span>Subtotal</span>
                <strong>@Invoice?.Subtotal.ToString("C2", new System.Globalization.CultureInfo("en-US"))</strong>
            </div>
            <div class="invd-total-row">
                <span>IVA (16%)</span>
                <strong>@Invoice?.Tax.ToString("C2", new System.Globalization.CultureInfo("en-US"))</strong>
            </div>
            <div class="invd-total-row invd-total-row--grand">
                <span>Total</span>
                <strong>@Invoice?.Total.ToString("C2", new System.Globalization.CultureInfo("en-US"))</strong>
            </div>
        </div>
    </div>
</section>

<style>
    .invd-table thead th {
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: var(--invd-muted);
        background: var(--invd-surface-soft);
        border-bottom-color: var(--invd-border);
    }

    .invd-table td {
        border-bottom-color: var(--invd-border);
        color: var(--invd-text);
        padding-top: 0.7rem;
        padding-bottom: 0.7rem;
    }

    .invd-subline {
        font-size: 0.78rem;
        color: var(--invd-muted);
    }

    .invd-subline--accent {
        color: var(--invd-primary);
    }

    .invd-totals {
        width: min(100%, 320px);
        border: 1px solid var(--invd-border);
        border-radius: 12px;
        background: var(--invd-surface-soft);
        padding: 0.75rem;
    }

    .invd-total-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.35rem 0;
        color: var(--invd-muted);
        font-size: 0.9rem;
    }

    .invd-total-row strong {
        color: var(--invd-text);
    }

    .invd-total-row--grand {
        margin-top: 0.2rem;
        border-top: 1px solid var(--invd-border-strong);
        padding-top: 0.55rem;
        font-size: 1rem;
        font-weight: 700;
    }

    .invd-total-row--grand strong {
        color: var(--invd-success);
    }
</style>

@code {
    [Parameter] public InvoiceDetailDto? Invoice { get; set; }
}
