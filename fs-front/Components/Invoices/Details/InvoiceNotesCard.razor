@if (!string.IsNullOrEmpty(Notes))
{
    <section class="invd-note">
        <h6 class="mb-2 d-flex align-items-center gap-2">
            <span class="invd-note__icon"><i class="bi bi-sticky"></i></span>
            Notas adicionales
        </h6>
        <p class="mb-0">@Notes</p>
    </section>
}

<style>
    .invd-note {
        border: 1px solid rgba(181, 71, 8, 0.28);
        background: var(--invd-warning-soft);
        border-radius: 12px;
        padding: 0.9rem 1rem;
        color: var(--invd-text);
    }

    .invd-note p {
        color: #7a2e0e;
        font-size: 0.92rem;
        line-height: 1.5;
    }

    .invd-note__icon {
        width: 1.55rem;
        height: 1.55rem;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: rgba(181, 71, 8, 0.14);
        color: var(--invd-warning);
        font-size: 0.8rem;
    }
</style>

@code {
    [Parameter] public string? Notes { get; set; }
}
