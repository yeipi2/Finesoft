@using fs_front.DTO

@if (Payments.Any())
{
    <section class="invd-panel">
        <header class="invd-panel__header d-flex justify-content-between align-items-center">
            <h5 class="mb-0 d-flex align-items-center gap-2">
                <span class="invd-icon-wrap"><i class="bi bi-cash-stack"></i></span>
                Historial de pagos
            </h5>
            <span class="invd-count">@Payments.Count</span>
        </header>

        <div class="invd-panel__body">
            <div class="table-responsive">
                <table class="table table-sm align-middle invd-table mb-0">
                    <thead>
                        <tr>
                            <th>Fecha</th>
                            <th>Método</th>
                            <th>Referencia</th>
                            <th class="text-end">Monto</th>
                            <th>Registrado por</th>
                            <th>Comprobante</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var payment in Payments)
                        {
                            <tr>
                                <td>@payment.PaymentDate.ToString("dd/MM/yyyy")</td>
                                <td>@payment.PaymentMethod</td>
                                <td>@payment.Reference</td>
                                <td class="text-end">
                                    <strong class="text-success">@payment.Amount.ToString("C2", new System.Globalization.CultureInfo("en-US"))</strong>
                                </td>
                                <td>@payment.RecordedByUserName</td>
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(payment.ReceiptPath))
                                    {
                                        <a class="btn btn-sm btn-outline-dark"
                                           href="@($"{ApiBaseUrl}{payment.ReceiptPath}")"
                                           target="_blank" rel="noopener">
                                            <i class="bi bi-download me-1"></i> Descargar
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </section>
}

<style>
    .invd-table thead th {
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: var(--invd-muted);
        background: var(--invd-surface-soft);
        border-bottom-color: var(--invd-border);
    }

    .invd-table td {
        border-bottom-color: var(--invd-border);
        color: var(--invd-text);
    }
</style>

@code {
    [Parameter] public List<InvoicePaymentDto> Payments { get; set; } = new();
    [Parameter] public string ApiBaseUrl { get; set; } = "";
}
