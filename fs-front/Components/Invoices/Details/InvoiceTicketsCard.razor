@using fs_front.DTO

@if (TicketsWithDetails.Any())
{
    <section class="invd-panel">
        <header class="invd-panel__header d-flex justify-content-between align-items-center">
            <h5 class="mb-0 d-flex align-items-center gap-2">
                <span class="invd-icon-wrap"><i class="bi bi-ticket-perforated-fill"></i></span>
                Tickets asociados
            </h5>
            <span class="invd-count">@TicketsWithDetails.Count</span>
        </header>

        <div class="invd-panel__body d-flex flex-column gap-2">
            @foreach (var item in TicketsWithDetails)
            {
                <article class="invd-ticket-row">
                    <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
                        <div class="flex-grow-1">
                            <div class="d-flex align-items-center gap-2 mb-2 flex-wrap">
                                <span class="invd-ticket-id">#@item.TicketId</span>
                                <h6 class="mb-0">@item.TicketTitle</h6>
                            </div>

                            @if (!string.IsNullOrEmpty(item.TicketDescription))
                            {
                                <p class="invd-ticket-desc mb-2">
                                    @(item.TicketDescription.Length > 150
                                        ? item.TicketDescription[..150] + "..."
                                        : item.TicketDescription)
                                </p>
                            }

                            <div class="row g-2 invd-ticket-meta">
                                <div class="col-md-4">
                                    <i class="bi bi-building"></i>
                                    <span>@item.TicketClientName</span>
                                </div>
                                <div class="col-md-4">
                                    <i class="bi bi-folder"></i>
                                    <span>@item.TicketProjectName</span>
                                </div>
                                <div class="col-md-4">
                                    <i class="bi bi-clock"></i>
                                    <span>@item.TicketActualHours?.ToString("0.0") h</span>
                                </div>
                            </div>
                        </div>

                        <a href="/tickets/@item.TicketId"
                           class="btn btn-sm btn-outline-dark"
                           target="_blank" rel="noopener">
                            <i class="bi bi-box-arrow-up-right me-1"></i> Abrir
                        </a>
                    </div>
                </article>
            }
        </div>
    </section>
}

<style>
    .invd-count {
        border-radius: 999px;
        background: var(--invd-primary-soft);
        color: var(--invd-primary);
        border: 1px solid rgba(21, 94, 239, 0.28);
        padding: 0.15rem 0.6rem;
        font-size: 0.78rem;
        font-weight: 700;
    }

    .invd-ticket-row {
        border: 1px solid var(--invd-border);
        border-radius: 12px;
        background: var(--invd-surface-soft);
        padding: 0.85rem;
    }

    .invd-ticket-id {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 999px;
        background: #e0f2fe;
        color: #075985;
        border: 1px solid #bae6fd;
        padding: 0.15rem 0.5rem;
        font-size: 0.76rem;
        font-weight: 700;
    }

    .invd-ticket-desc {
        color: var(--invd-muted);
        font-size: 0.88rem;
    }

    .invd-ticket-meta {
        font-size: 0.82rem;
        color: var(--invd-muted);
    }

    .invd-ticket-meta i {
        margin-right: 0.3rem;
    }
</style>

@code {
    [Parameter] public List<InvoiceItemDetailDto> TicketsWithDetails { get; set; } = new();
}
