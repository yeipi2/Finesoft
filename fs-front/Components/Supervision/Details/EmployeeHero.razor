@using fs_front.DTO

<div class="employee-hero d-flex justify-content-between align-items-start gap-3 flex-wrap">
    <div class="d-flex align-items-center gap-3">
        @if (!string.IsNullOrEmpty(Employee?.AvatarDataUrl))
        {
            <img src="@Employee.AvatarDataUrl" class="avatar-large-img" alt="@Employee.FullName" />
        }
        else
        {
            <div class="avatar-large">
                @GetInitials(Employee?.FullName ?? "")
            </div>
        }
        <div>
            <h1 class="h3 fw-bold mb-1">@Employee?.FullName</h1>
            <div class="d-flex gap-2 flex-wrap">
                <span class="badge bg-@GetRoleBadgeColor(Employee?.RoleName ?? "")">@Employee?.RoleName</span>
                @if (Employee?.IsActive == true)
                {
                    <span class="badge bg-success">Activo</span>
                }
                else
                {
                    <span class="badge bg-secondary">Inactivo</span>
                }
            </div>
        </div>
    </div>
    <button class="btn btn-outline-dark" @onclick="OnGoBack">
        <i class="bi bi-arrow-left me-1"></i> Volver
    </button>
</div>

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/dashboard">Panel</a></li>
        <li class="breadcrumb-item"><a href="/supervisor/empleados">Supervisión</a></li>
        <li class="breadcrumb-item active">@Employee?.FullName</li>
    </ol>
</nav>

@code {
    [Parameter] public EmployeeSummaryDto? Employee { get; set; }
    [Parameter] public EventCallback OnGoBack { get; set; }

    private string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2) return $"{parts[0][0]}{parts[1][0]}".ToUpper();
        return name.Length >= 2 ? name.Substring(0, 2).ToUpper() : name.ToUpper();
    }

    private string GetRoleBadgeColor(string role) => role switch
    {
        "Admin" => "danger",
        "Supervisor" => "warning",
        "Administracion" => "info",
        "Empleado" => "primary",
        "Cliente" => "secondary",
        _ => "secondary"
    };
}
