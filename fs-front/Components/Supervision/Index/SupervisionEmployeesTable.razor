@using fs_front.DTO

<div class="card">
    <div class="card-body p-0">
        @if (IsLoading)
        {
            <div class="text-center py-5">
                <div class="spinner-border text-primary" role="status"></div>
                <p class="mt-2 text-muted">Cargando empleados...</p>
            </div>
        }
        else if (Employees == null || !Employees.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-people display-1 text-muted"></i>
                <p class="mt-3 text-muted">No hay empleados registrados</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Empleado</th>
                            <th>Puesto</th>
                            <th>Departamento</th>
                            <th>Rol</th>
                            <th>Última Actividad</th>
                            <th>Estado</th>
                            <th class="text-end pe-4">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var emp in Employees)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-circle me-2">
                                            @GetInitials(emp.FullName)
                                        </div>
                                        <div>
                                            <div class="fw-semibold">@emp.FullName</div>
                                            <small class="text-muted">@emp.Email</small>
                                        </div>
                                    </div>
                                </td>
                                <td>@emp.Position</td>
                                <td>@(string.IsNullOrEmpty(emp.Department) ? "-" : emp.Department)</td>
                                <td>
                                    <span class="badge bg-@GetRoleBadgeColor(emp.RoleName)">
                                        @emp.RoleName
                                    </span>
                                </td>
                                <td>
                                    @if (emp.LastActivityDate.HasValue)
                                    {
                                        <span title="@emp.LastActivityDate.Value.ToString("g")">
                                            @GetRelativeTime(emp.LastActivityDate.Value)
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Sin actividad</span>
                                    }
                                </td>
                                <td>
                                    @if (emp.IsActive)
                                    {
                                        <span class="badge bg-success">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactivo</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <button class="btn btn-sm btn-outline-primary"
                                            @onclick="() => OnViewHistory.InvokeAsync(emp.UserId)"
                                            title="Ver historial">
                                        <i class="bi bi-eye-fill"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (TotalPages > 1)
            {
                <div class="card-footer bg-transparent">
                    <div class="d-flex justify-content-between align-items-center">
                        <div class="text-muted small">
                            Mostrando @((CurrentPage - 1) * PageSize + 1) - @Math.Min(CurrentPage * PageSize, TotalCount) de @TotalCount
                        </div>
                        <nav>
                            <ul class="pagination mb-0">
                                <li class="page-item @(CurrentPage == 1 ? "disabled" : "")">
                                    <button class="page-link" @onclick="() => OnPageChange.InvokeAsync(CurrentPage - 1)">
                                        <i class="bi bi-chevron-left"></i>
                                    </button>
                                </li>
                                @for (int i = Math.Max(1, CurrentPage - 2); i <= Math.Min(TotalPages, CurrentPage + 2); i++)
                                {
                                    <li class="page-item @(CurrentPage == i ? "active" : "")">
                                        <button class="page-link" @onclick="() => OnPageChange.InvokeAsync(i)">@i</button>
                                    </li>
                                }
                                <li class="page-item @(CurrentPage == TotalPages ? "disabled" : "")">
                                    <button class="page-link" @onclick="() => OnPageChange.InvokeAsync(CurrentPage + 1)">
                                        <i class="bi bi-chevron-right"></i>
                                    </button>
                                </li>
                            </ul>
                        </nav>
                    </div>
                </div>
            }
        }
    </div>
</div>

@code {
    [Parameter] public List<EmployeeSummaryDto>? Employees { get; set; }
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public int CurrentPage { get; set; } = 1;
    [Parameter] public int PageSize { get; set; } = 15;
    [Parameter] public int TotalCount { get; set; }
    [Parameter] public int TotalPages { get; set; }

    [Parameter] public EventCallback<string> OnViewHistory { get; set; }
    [Parameter] public EventCallback<int> OnPageChange { get; set; }

    private string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2) return $"{parts[0][0]}{parts[1][0]}".ToUpper();
        return name.Length >= 2 ? name.Substring(0, 2).ToUpper() : name.ToUpper();
    }

    private string GetRoleBadgeColor(string role) => role switch
    {
        "Admin" => "danger",
        "Supervisor" => "warning",
        "Administracion" => "info",
        "Empleado" => "primary",
        "Cliente" => "secondary",
        _ => "secondary"
    };

    private string GetRelativeTime(DateTime date)
    {
        var span = DateTime.Now - date;
        if (span.TotalMinutes < 1) return "Hace un momento";
        if (span.TotalMinutes < 60) return $"Hace {(int)span.TotalMinutes} min";
        if (span.TotalHours < 24) return $"Hace {(int)span.TotalHours} hrs";
        if (span.TotalDays < 7) return $"Hace {(int)span.TotalDays} días";
        return date.ToString("dd MMM");
    }
}
