@using fs_front.DTO

@if (CanManage)
{
    <section class="td-panel">
        <header class="td-panel__header d-flex justify-content-between align-items-center gap-2 flex-wrap">
            <div>
                <h5 class="mb-0 d-flex align-items-center gap-2">
                    <span class="td-icon-wrap"><i class="bi bi-list-task"></i></span>
                    Actividades
                </h5>
                <small class="text-muted">
                    @(Activities?.Count(a => !a.IsCompleted) ?? 0) pendientes -
                    @(Activities?.Count(a => a.IsCompleted) ?? 0) completadas
                </small>
            </div>

            <div class="d-flex gap-2 flex-wrap justify-content-end">
                @if (!ActivitiesAreLocked && Status != "Cerrado")
                {
                    <button class="btn btn-dark btn-sm" @onclick="OnAddActivity">
                        <i class="bi bi-plus-lg me-1"></i> Agregar
                    </button>
                }

                @if (Activities != null && Activities.Any())
                {
                    @if (Status == "Abierto")
                    {
                        <button class="btn btn-success btn-sm" @onclick="OnLock" title="Bloquear actividades y comenzar trabajo">
                            <i class="bi bi-lock me-1"></i> Bloquear
                        </button>
                    }
                    else if (Status == "En Progreso")
                    {
                        var allCompleted = Activities.Any() && Activities.All(a => a.IsCompleted);

                        <button class="btn btn-secondary btn-sm" @onclick="OnUnlock" title="Desbloquear actividades para editar">
                            <i class="bi bi-unlock me-1"></i> Desbloquear
                        </button>

                        @if (allCompleted)
                        {
                            <button class="btn btn-info btn-sm" @onclick="OnPassToReview" title="Pasar ticket a revisión">
                                <i class="bi bi-eye-fill me-1"></i> Revisar
                            </button>
                        }
                    }
                    else if (Status == "En Revisión")
                    {
                        <button class="btn btn-success btn-sm" @onclick="OnClose" title="Marcar ticket como completado">
                            <i class="bi bi-check-circle-fill me-1"></i> Cerrar
                        </button>
                        <button class="btn btn-warning btn-sm" @onclick="OnUnlock" title="Regresar a edición">
                            <i class="bi bi-arrow-counterclockwise me-1"></i> Regresar
                        </button>
                    }
                }
            </div>
        </header>

        <div class="td-panel__body">
            @if (Activities != null && Activities.Any())
            {
                <div class="d-flex flex-column gap-2">
                    @foreach (var activity in Activities.OrderBy(a => a.IsCompleted).ThenBy(a => a.CreatedAt))
                    {
                        <article class="td-activity-row @(activity.IsCompleted ? "td-activity-row--done" : string.Empty)">
                            <div class="d-flex justify-content-between align-items-start gap-2">
                                <div class="flex-grow-1">
                                    <div class="d-flex align-items-center gap-2 mb-1">
                                        @if (activity.IsCompleted)
                                        {
                                            <i class="bi bi-check-circle-fill text-success"></i>
                                            <span class="text-decoration-line-through text-muted">@activity.Description</span>
                                        }
                                        else
                                        {
                                            <i class="bi bi-circle text-muted"></i>
                                            <strong>@activity.Description</strong>
                                        }
                                    </div>

                                    <small class="text-muted d-block">
                                        <i class="bi bi-clock me-1"></i>@activity.HoursSpent.ToString("0.00")h
                                        | <i class="bi bi-person me-1"></i>@activity.CreatedByUserName
                                        @if (activity.IsCompleted && activity.CompletedAt.HasValue)
                                        {
                                            <span> | Completada: @activity.CompletedAt.Value.ToString("dd/MM/yyyy HH:mm")</span>
                                        }
                                    </small>
                                </div>

                                <div class="d-flex gap-1">
                                    @if (!activity.IsCompleted && ActivitiesAreLocked)
                                    {
                                        <button class="btn btn-success btn-sm" @onclick="() => OnCompleteActivity.InvokeAsync(activity.Id)" title="Marcar como completada">
                                            <i class="bi bi-check-lg"></i>
                                        </button>
                                    }
                                    @if (!activity.IsCompleted && !ActivitiesAreLocked && Status != "Cerrado")
                                    {
                                        <button class="btn btn-primary btn-sm" @onclick="() => OnEditActivity.InvokeAsync(activity)" title="Editar">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <button class="btn btn-danger btn-sm" @onclick="() => OnDeleteActivity.InvokeAsync(activity)" title="Eliminar">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    }
                                </div>
                            </div>
                        </article>
                    }
                </div>

                @if (ActivitiesAreLocked)
                {
                    @if (Status == "En Progreso")
                    {
                        <div class="alert alert-info mt-3 mb-0">
                            <i class="bi bi-info-circle me-1"></i>
                            Las actividades están bloqueadas. Marca todas como completadas para pasar a revisión.
                        </div>
                    }
                    else if (Status == "En Revisión")
                    {
                        <div class="alert alert-success mt-3 mb-0">
                            <i class="bi bi-check-circle me-1"></i>
                            Ticket en revisión. Todas las actividades han sido completadas.
                        </div>
                    }
                }
            }
            else
            {
                <div class="text-center py-4">
                    <i class="bi bi-clipboard-x text-muted" style="font-size: 2.6rem;"></i>
                    <p class="text-muted mt-2 mb-1">No hay actividades registradas.</p>
                    <p class="text-muted small mb-0">Agrega tareas para estructurar el trabajo del ticket.</p>
                </div>
            }
        </div>
    </section>
}

<style>
    .td-activity-row {
        border: 1px solid var(--td-border);
        border-radius: 10px;
        background: var(--td-surface-soft);
        padding: 0.75rem;
    }

    .td-activity-row--done {
        opacity: 0.9;
    }
</style>

@code {
    [Parameter, EditorRequired] public List<TicketActivityDto>? Activities { get; set; }
    [Parameter, EditorRequired] public string Status { get; set; } = string.Empty;
    [Parameter] public bool CanManage { get; set; }
    [Parameter] public bool ActivitiesAreLocked { get; set; }
    [Parameter] public EventCallback OnAddActivity { get; set; }
    [Parameter] public EventCallback OnLock { get; set; }
    [Parameter] public EventCallback OnUnlock { get; set; }
    [Parameter] public EventCallback OnPassToReview { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback<int> OnCompleteActivity { get; set; }
    [Parameter] public EventCallback<TicketActivityDto> OnEditActivity { get; set; }
    [Parameter] public EventCallback<TicketActivityDto> OnDeleteActivity { get; set; }
}
