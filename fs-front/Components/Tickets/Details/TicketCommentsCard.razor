@using fs_front.DTO

<section class="td-panel">
    <header class="td-panel__header d-flex justify-content-between align-items-center">
        <h5 class="mb-0 d-flex align-items-center gap-2">
            <span class="td-icon-wrap"><i class="bi bi-chat-dots"></i></span>
            Comentarios
        </h5>
        <span class="td-count">@(Comments?.Count ?? 0)</span>
    </header>

    <div class="td-panel__body">
        @if (Comments != null && Comments.Any())
        {
            @foreach (var comment in Comments.OrderBy(c => c.CreatedAt))
            {
                <article class="td-comment-row @(comment.IsInternal ? "td-comment-row--internal" : string.Empty)">
                    <div class="d-flex justify-content-between align-items-start mb-1">
                        <div>
                            <strong>@comment.UserName</strong>
                            @if (comment.IsInternal)
                            {
                                <span class="badge text-bg-warning ms-2">Interno</span>
                            }
                        </div>
                        <small class="text-muted">@comment.CreatedAt?.ToString("dd/MM/yyyy HH:mm")</small>
                    </div>
                    <p class="mb-0">@comment.Comment</p>
                </article>
            }
        }
        else
        {
            <p class="text-muted text-center py-3 mb-0">No hay comentarios aún.</p>
        }

        @if (CanComment)
        {
            <div class="td-comment-form mt-4">
                <EditForm Model="NewComment" OnValidSubmit="OnAddComment">
                    <DataAnnotationsValidator />
                    <div class="mb-3">
                        <label class="form-label fw-semibold small">Agregar comentario</label>
                        <InputTextArea class="form-control" rows="3"
                                       @bind-Value="NewComment.Comment"
                                       placeholder="Escribe tu comentario aquí..." />
                        <ValidationMessage For="@(() => NewComment.Comment)" />
                    </div>
                    <button type="submit" class="btn btn-primary btn-sm" disabled="@IsSaving">
                        @if (IsSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        <i class="bi bi-send me-1"></i> Agregar comentario
                    </button>
                </EditForm>
            </div>
        }
    </div>
</section>

<style>
    .td-count {
        border-radius: 999px;
        background: #e8efff;
        color: #1d4ed8;
        border: 1px solid rgba(29, 78, 216, 0.32);
        padding: 0.15rem 0.6rem;
        font-size: 0.78rem;
        font-weight: 700;
    }

    .td-comment-row {
        border: 1px solid var(--td-border);
        border-left: 3px solid #1d4ed8;
        border-radius: 10px;
        background: var(--td-surface-soft);
        padding: 0.75rem;
        margin-bottom: 0.75rem;
    }

    .td-comment-row:last-child {
        margin-bottom: 0;
    }

    .td-comment-row--internal {
        border-left-color: #b45309;
    }

    .td-comment-row p {
        font-size: 0.92rem;
        color: var(--td-text);
    }

    .td-comment-form {
        border-top: 1px dashed var(--td-border);
        padding-top: 1rem;
    }
</style>

@code {
    [Parameter, EditorRequired] public List<TicketCommentDto>? Comments { get; set; }
    [Parameter] public bool CanComment { get; set; }
    [Parameter] public bool IsSaving { get; set; }
    [Parameter, EditorRequired] public TicketCommentDto NewComment { get; set; } = default!;
    [Parameter] public EventCallback OnAddComment { get; set; }
}
