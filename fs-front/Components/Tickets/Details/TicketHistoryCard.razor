@using fs_front.DTO

<section class="td-panel">
    <header class="td-panel__header td-panel__header--clickable" @onclick="Toggle">
        <div class="d-flex justify-content-between align-items-center">
            <h5 class="mb-0 d-flex align-items-center gap-2">
                <span class="td-icon-wrap"><i class="bi bi-clock-history"></i></span>
                Historial de cambios
                @if (History != null && History.Any())
                {
                    <span class="td-count">@History.Count</span>
                }
            </h5>
            <i class="bi @(_collapsed ? "bi-chevron-down" : "bi-chevron-up")"></i>
        </div>
    </header>

    <div class="collapse @(_collapsed ? string.Empty : "show")">
        <div class="td-panel__body td-history-body">
            @if (History != null && History.Any())
            {
                @foreach (var h in History.OrderByDescending(x => x.ChangedAt))
                {
                    <article class="td-history-row">
                        <div class="d-flex justify-content-between align-items-start gap-2">
                            <div>
                                <strong>@h.UserName</strong>
                                <span class="text-muted"> - @h.Action</span>
                            </div>
                            <small class="text-muted">@h.ChangedAt.ToString("dd/MM/yyyy HH:mm")</small>
                        </div>

                        @if (!string.IsNullOrEmpty(h.OldValue) || !string.IsNullOrEmpty(h.NewValue))
                        {
                            <small class="text-muted d-block mt-1">
                                @if (!string.IsNullOrEmpty(h.OldValue))
                                {
                                    <span>De: <span class="text-decoration-line-through">@h.OldValue</span></span>
                                }
                                @if (!string.IsNullOrEmpty(h.NewValue))
                                {
                                    <span> A: <strong>@h.NewValue</strong></span>
                                }
                            </small>
                        }
                    </article>
                }
            }
            else
            {
                <p class="text-muted text-center py-3 mb-0">No hay historial disponible.</p>
            }
        </div>
    </div>
</section>

<style>
    .td-panel__header--clickable {
        cursor: pointer;
        user-select: none;
    }

    .td-history-body {
        max-height: 400px;
        overflow-y: auto;
    }

    .td-history-row {
        border-left: 2px solid var(--td-primary-border);
        background: var(--td-surface-soft);
        border-radius: 8px;
        padding: 0.7rem;
        margin-bottom: 0.6rem;
    }

    .td-history-row:last-child {
        margin-bottom: 0;
    }
</style>

@code {
    [Parameter, EditorRequired] public List<TicketHistoryDto>? History { get; set; }

    private bool _collapsed = true;

    private void Toggle() => _collapsed = !_collapsed;
}
