@page "/empleados"
@using fs_front.DTO
@using fs_front.Services
@using fs_front.Repositories
@using fs_front.Components.Employees.Index
@using fs_front.Components.Employees.Form
@using fs_front.Components.Shared
@inject IEmployeeApiService EmployeeApiService
@inject ITicketApiService TicketApiService
@inject DialogService DialogService
@inject NotificationService NotificationService
@inject IPermissionService PermissionService
@inject NavigationManager NavigationManager

@attribute [Authorize]

<PageTitle>Finesoft - Empleados</PageTitle>

@if (_checkingAccess)
{
    <div style="position:fixed;top:0;left:0;width:100vw;height:100vh;
                background:white;z-index:9999;
                display:flex;align-items:center;justify-content:center;">
        <div class="spinner-border text-primary" role="status"></div>
    </div>
}
else if (!_hasAccess)
{
    <div></div>
}
else
{
    <div class="fs-index-layout">

        <section class="fs-index-section">
            <EmployeesHeader CanCreate="_canCreate"
                             OnCreateClicked="ShowCreateModal" />
        </section>

        <section class="fs-index-section">
            <FilterBar
                       SearchPlaceholder="Buscar empleados..."
                       SearchValue="@_searchTerm"
                       SearchValueChanged="@OnSearchChanged"
                       OnClear="ClearFilters">
                <Filters>
                    <select class="form-select" @bind="_statusFilter" @bind:event="onchange" @bind:after="OnStatusFilterChanged">
                        <option value="Todos">Estados</option>
                        <option value="Activos">Activos</option>
                        <option value="Inactivos">Inactivos</option>
                    </select>
                </Filters>
            </FilterBar>
        </section>

        <section class="fs-index-section">
            <EmployeesTable Items="_employees"
                            IsLoading="_isLoading"
                            CanEdit="_canEdit"
                            SortField="_sortField"
                            SortDir="_sortDir"
                            SortChanged="OnSortChanged"
                            OnEditClicked="ShowEditModal"
                            OnToggleStatusClicked="ToggleEmployeeStatus"
                            EmptyTitle="@(_employees == null || !_employees.Any() ? "No hay empleados registrados" : "No se encontraron empleados")" />
        </section>

        @if (_totalPages > 0)
        {
            <section class="fs-index-section">
                <Pagination CurrentPage="_currentPage"
                            PageSize="_pageSize"
                            TotalCount="_totalCount"
                            PageChanged="OnPageChanged"
                            PageSizeChanged="OnPageSizeChanged" />
            </section>
        }

    </div>
}

@code {
    private List<EmployeeDto> _employees = new();
    private string _statusFilter = "Todos";

    private bool _checkingAccess = true;
    private bool _hasAccess = false;
    private bool _canCreate;
    private bool _canEdit;
    private bool _isLoading = false;

    private string _searchTerm = "";
    private string _sortField = "fullName";
    private FsSortHeader.SortDirection _sortDir = FsSortHeader.SortDirection.Desc;

    // Paginación
    private int _currentPage = 1;
    private int _pageSize = 20;
    private int _totalCount = 0;
    private int _totalPages => _pageSize > 0 ? (int)Math.Ceiling(_totalCount / (double)_pageSize) : 0;

    private void OnSortChanged((string field, FsSortHeader.SortDirection dir) s)
    {
        _sortField = s.field;
        _sortDir = s.dir;
        _ = LoadEmployees();
    }

    protected override async Task OnInitializedAsync()
    {
        var canView = await PermissionService.HasPermissionAsync("employees.view");

        if (!canView)
        {
            _checkingAccess = false;
            _hasAccess = false;
            NavigationManager.NavigateTo("/dashboard", forceLoad: true);
            return;
        }

        _hasAccess = true;
        _checkingAccess = false;

        _canCreate = await PermissionService.HasPermissionAsync("employees.create");
        _canEdit = await PermissionService.HasPermissionAsync("employees.edit");

        await LoadEmployees();
    }

    private async Task LoadEmployees()
    {
        _isLoading = true;
        try
        {
            var sortDescending = _sortDir == FsSortHeader.SortDirection.Desc;

            var statusParam = _statusFilter == "Todos" ? null : _statusFilter;

            var result = await EmployeeApiService.GetEmployeesPaginatedAsync(
                search: string.IsNullOrWhiteSpace(_searchTerm) ? null : _searchTerm,
                status: statusParam,
                page: _currentPage,
                pageSize: _pageSize,
                sortField: _sortField,
                sortDescending: sortDescending
            );

            if (result != null)
            {
                _employees = result.Items;
                _totalCount = result.Total;
            }
            else
            {
                _employees = new List<EmployeeDto>();
                _totalCount = 0;
            }
            StateHasChanged();
        }
        catch (Exception e)
        {
            Console.WriteLine(e);
            ShowNotification("Error", "No se pudo cargar la lista de empleados.", NotificationSeverity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task OnSearchChanged(string value)
    {
        if (_searchTerm == value) return;
        _searchTerm = value;
        _currentPage = 1;
        await LoadEmployees();
    }

    private async Task OnStatusFilterChanged()
    {
        _currentPage = 1;
        await LoadEmployees();
    }

    private async Task ClearFilters()
    {
        _searchTerm = string.Empty;
        _statusFilter = "Todos";
        _currentPage = 1;
        await LoadEmployees();
    }

    private async Task OnPageChanged(int page)
    {
        _currentPage = page;
        await LoadEmployees();
    }

    private async Task OnPageSizeChanged(int newSize)
    {
        _pageSize = newSize;
        _currentPage = 1;
        await LoadEmployees();
    }

    private async Task ShowCreateModal()
    {
        var result = await DialogService.OpenAsync<EmployeeForm>("Crear Empleado",
            options: new DialogOptions { Width = "800px", Resizable = false, Draggable = false });
        if (result == true) await LoadEmployees();
    }

    private async Task ShowEditModal(int? employeeId)
    {
        var parameters = new Dictionary<string, object> { { "EmployeeId", employeeId } };
        var result = await DialogService.OpenAsync<EmployeeForm>("Editar Empleado", parameters,
            options: new DialogOptions { Width = "800px", Resizable = false, Draggable = false });
        if (result == true) await LoadEmployees();
    }

    private async Task ToggleEmployeeStatus(EmployeeDto employee)
    {
        var actionText = employee.IsActive ? "desactivar" : "activar";
        string confirmMessage;

        // Solo si se va a DESACTIVAR, contar tickets activos asignados
        if (employee.IsActive)
        {
            int activeTickets = 0;
            try
            {
                var tickets = await TicketApiService.GetTicketsAsync();
                var activeStatuses = new[] { "Abierto", "En Progreso", "En Revisión" };
                activeTickets = tickets?
                    .Count(t => t.AssignedToUserId == employee.UserId
                                && activeStatuses.Contains(t.Status)) ?? 0;
            }
            catch
            {
                // Si falla la consulta de tickets, continuamos sin el conteo
            }

            if (activeTickets > 0)
            {
                var ticketWord = activeTickets == 1 ? "ticket activo" : "tickets activos";
                confirmMessage =
                    $"¿Estás seguro de que quieres desactivar a {employee.FullName}? " +
                    $"Esta acción dejará {activeTickets} {ticketWord} sin asignar.";
            }
            else
            {
                confirmMessage =
                    $"¿Estás seguro de que quieres desactivar a {employee.FullName}?";
            }
        }
        else
        {
            confirmMessage = $"¿Estás seguro de que quieres activar a {employee.FullName}?";
        }

        var confirmed = await DialogService.Confirm(
            confirmMessage,
            $"Confirmar {actionText}",
            new ConfirmOptions
            {
                OkButtonText = $"Sí, {actionText}",
                CancelButtonText = "Cancelar"
            });

        if (confirmed != true) return;

        try
        {
            var (success, errorMessage, unassignedTickets) =
                await EmployeeApiService.ToggleEmployeeStatusAsync(employee.Id!.Value);

            if (success)
            {
                ShowNotification(
                    "Éxito",
                    $"Empleado {(employee.IsActive ? "desactivado" : "activado")} correctamente.",
                    NotificationSeverity.Success);

                // Notificación extra si quedaron tickets sin asignar
                if (unassignedTickets > 0)
                {
                    var ticketWord = unassignedTickets == 1 ? "ticket" : "tickets";
                    ShowNotification(
                        "Tickets desasignados",
                        $"{unassignedTickets} {ticketWord} activo(s) quedaron sin asignar.",
                        NotificationSeverity.Warning);
                }

                await LoadEmployees();
            }
            else
            {
                ShowNotification("Error", errorMessage ?? "No se pudo actualizar.", NotificationSeverity.Error);
            }
        }
        catch (Exception ex)
        {
            ShowNotification("Error", ex.Message, NotificationSeverity.Error);
        }
    }

    private void ShowNotification(string title, string message, NotificationSeverity severity) =>
        NotificationService.Notify(new NotificationMessage
        {
            Severity = severity,
            Summary = title,
            Detail = message,
            Duration = 4000
        });
}
