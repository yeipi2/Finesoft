@page "/supervisor/empleados/{UserId}"
@using fs_front.DTO
@using fs_front.Services
@using fs_front.Repositories
@inject ISupervisorApiService SupervisorApiService
@inject NavigationManager NavigationManager
@inject IPermissionService PermissionService
@inject NotificationService NotificationService
@inject fs_front.Services.ThemeService ThemeService

@attribute [Authorize]

<PageTitle>Historial de Empleado - Finesoft</PageTitle>

<SupervisionStyles />

@if (_isLoading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Cargando...</span>
        </div>
        <p class="mt-2" style="color: var(--suph-muted)">Cargando historial del empleado...</p>
    </div>
}
else if (_employee == null)
{
    <div class="container p-4">
        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle"></i> Empleado no encontrado.
        </div>
        <button class="btn btn-secondary" @onclick="GoBack">
            <i class="bi bi-arrow-left"></i> Volver
        </button>
    </div>
}
else
{
    <div class="supervisor-history-page container-fluid px-3 px-lg-4 py-4">
        <div class="row mb-4">
            <div class="col">
                <EmployeeHero 
                    Employee="@_employee" 
                    OnGoBack="GoBack" />
            </div>
        </div>

        <div class="row g-4">
            <div class="col-lg-8 d-flex flex-column gap-4">
                <EmployeeInfoCard Employee="@_employee" />

                <EmployeeHistoryCard 
                    ActionsByClient="@_actionsByClient"
                    IsLoading="@_isLoadingActions"
                    TotalCount="@_totalCount"
                    CurrentPage="@_currentPage"
                    TotalPages="@_totalPages"
                    ActionTypeFilter="@_actionTypeFilter"
                    DateFromStr="@_dateFromStr"
                    DateToStr="@_dateToStr"
                    ExpandedClients="@_expandedClients"
                    OnActionTypeChange="OnActionTypeChange"
                    OnDateFromChange="OnDateFromChange"
                    OnDateToChange="OnDateToChange"
                    OnClearFilters="ClearFilters"
                    OnToggleClient="ToggleClient"
                    OnShowDetails="ShowActionDetails"
                    OnPageChange="ChangePage" />
            </div>

            <div class="col-lg-4 d-flex flex-column gap-4">
                <EmployeeStatsCard Stats="@_stats" />
                <EmployeeActivityTimeline Actions="@_recentActions" />
            </div>
        </div>
    </div>
}

@if (_selectedAction != null)
{
    <div class="modal fade show" style="display: block; background: rgba(0,0,0,0.5)" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="background: var(--suph-surface); color: var(--suph-text)">
                <div class="modal-header" style="background: @_selectedAction.ColorCss; color: white">
                    <h5 class="modal-title">
                        <i class="bi @_selectedAction.IconCss me-2"></i>@_selectedAction.ActionTypeDisplay
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label small" style="color: var(--suph-muted)">Entidad</label>
                            <p class="mb-0 fw-semibold">@_selectedAction.EntityName</p>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label small" style="color: var(--suph-muted)">Fecha</label>
                            <p class="mb-0">@_selectedAction.Date.ToString("g")</p>
                        </div>
                        @if (!string.IsNullOrEmpty(_selectedAction.RelatedClientName))
                        {
                            <div class="col-md-6 mb-3">
                                <label class="form-label small" style="color: var(--suph-muted)">Cliente</label>
                                <p class="mb-0">@_selectedAction.RelatedClientName</p>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(_selectedAction.RelatedProjectName))
                        {
                            <div class="col-md-6 mb-3">
                                <label class="form-label small" style="color: var(--suph-muted)">Proyecto</label>
                                <p class="mb-0">@_selectedAction.RelatedProjectName</p>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(_selectedAction.Details))
                        {
                            <div class="col-12">
                                <label class="form-label small" style="color: var(--suph-muted)">Detalles</label>
                                <p class="mb-0">@_selectedAction.Details</p>
                            </div>
                        }
                    </div>
                </div>
                <div class="modal-footer">
                    @if (!string.IsNullOrEmpty(_selectedAction.EntityUrl))
                    {
                        <a href="@_selectedAction.EntityUrl" target="_blank" class="btn btn-primary">
                            <i class="bi bi-box-arrow-up-right me-1"></i>Ver en sistema
                        </a>
                    }
                    <button class="btn btn-secondary" @onclick="CloseModal">Cerrar</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string UserId { get; set; } = "";

    private EmployeeSummaryDto? _employee;
    private EmployeeStatsDto? _stats;
    private List<EmployeeActionDto>? _allActions;
    private Dictionary<string, List<EmployeeActionDto>>? _actionsByClient;
    private List<EmployeeActionDto>? _recentActions;
    private EmployeeActionDto? _selectedAction;

    private HashSet<string> _expandedClients = new();

    private bool _isLoading = true;
    private bool _isLoadingActions = true;

    private string _actionTypeFilter = "";
    private string _dateFromStr = "";
    private string _dateToStr = "";
    private DateTime? _dateFrom;
    private DateTime? _dateTo;

    private int _currentPage = 1;
    private int _pageSize = 50;
    private int _totalCount;
    private int _totalPages;

    protected override async Task OnInitializedAsync()
    {
        await LoadEmployeeDetails();
        await LoadStats();
        await LoadActions();
        await LoadRecentActions();
    }

    private async Task LoadEmployeeDetails()
    {
        _isLoading = true;
        try
        {
            _employee = await SupervisorApiService.GetEmployeeDetailsAsync(UserId);
        }
        catch (Exception e)
        {
            Console.WriteLine($"Error loading employee: {e.Message}");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadStats()
    {
        try
        {
            _stats = await SupervisorApiService.GetEmployeeStatsAsync(UserId);
        }
        catch (Exception e)
        {
            Console.WriteLine($"Error loading stats: {e.Message}");
        }
    }

    private async Task LoadActions()
    {
        _isLoadingActions = true;
        try
        {
            EmployeeActionType? actionType = null;
            if (!string.IsNullOrEmpty(_actionTypeFilter) && Enum.TryParse<EmployeeActionType>(_actionTypeFilter, out var parsed))
                actionType = parsed;

            var result = await SupervisorApiService.GetEmployeeHistoryAsync(
                UserId, 1, 100, actionType, _dateFrom, _dateTo
            );

            _allActions = result.Items;
            _totalCount = result.TotalCount;
            _totalPages = result.TotalPages;

            GroupActionsByClient();
        }
        catch (Exception e)
        {
            Console.WriteLine($"Error loading actions: {e.Message}");
        }
        finally
        {
            _isLoadingActions = false;
        }
    }

    private void GroupActionsByClient()
    {
        if (_allActions == null || !_allActions.Any())
        {
            _actionsByClient = new Dictionary<string, List<EmployeeActionDto>>();
            return;
        }

        _actionsByClient = _allActions
            .GroupBy(a => string.IsNullOrEmpty(a.RelatedClientName) ? "Sin cliente" : a.RelatedClientName)
            .ToDictionary(g => g.Key, g => g.OrderByDescending(a => a.Date).ToList());

        foreach (var key in _actionsByClient.Keys.ToList())
            _expandedClients.Add(key);
    }

    private async Task LoadRecentActions()
    {
        try
        {
            var result = await SupervisorApiService.GetEmployeeHistoryAsync(UserId, 1, 10);
            _recentActions = result.Items;
        }
        catch (Exception e)
        {
            Console.WriteLine($"Error loading recent actions: {e.Message}");
        }
    }

    private async Task OnActionTypeChange(string value)
    {
        _actionTypeFilter = value;
        _currentPage = 1;
        await LoadActions();
    }

    private async Task OnDateFromChange(string value)
    {
        _dateFromStr = value;
        _dateFrom = string.IsNullOrEmpty(value) ? null : DateTime.Parse(value);
        _currentPage = 1;
        await LoadActions();
    }

    private async Task OnDateToChange(string value)
    {
        _dateToStr = value;
        _dateTo = string.IsNullOrEmpty(value) ? null : DateTime.Parse(value);
        _currentPage = 1;
        await LoadActions();
    }

    private async Task ClearFilters()
    {
        _actionTypeFilter = "";
        _dateFromStr = "";
        _dateToStr = "";
        _dateFrom = null;
        _dateTo = null;
        _currentPage = 1;
        await LoadActions();
    }

    private async Task ChangePage(int page)
    {
        if (page < 1 || page > _totalPages) return;
        _currentPage = page;
        await LoadActions();
    }

    private void ToggleClient(string clientName)
    {
        if (_expandedClients.Contains(clientName))
            _expandedClients.Remove(clientName);
        else
            _expandedClients.Add(clientName);
    }

    private void ShowActionDetails(EmployeeActionDto action) => _selectedAction = action;
    private void CloseModal() => _selectedAction = null;
    private void GoBack() => NavigationManager.NavigateTo("/supervisor/empleados");
}
