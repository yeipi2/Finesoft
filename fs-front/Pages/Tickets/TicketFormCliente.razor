@* Formulario para que clientes creen tickets.
   El proyecto se asigna automáticamente si tiene uno. *@
@using fs_front.DTO

@inject ITicketApiService TicketApiService
@inject DialogService DialogService
@inject NotificationService NotificationService

<section class="container px-0">
    @* Información del cliente *@
    <div class="alert alert-primary d-flex align-items-center gap-2 mb-4">
        <i class="bi bi-person-circle fs-5"></i>
        <div>
            <strong>Ticket para:</strong> @ClientEmail
        </div>
    </div>

    @* Información del proyecto (solo informativo, no se puede cambiar) *@
    @if (_projects != null && _projects.Count > 0)
    {
        <div class="alert alert-success d-flex align-items-center gap-2 mb-4">
            <i class="bi bi-folder-check fs-5"></i>
            <div>
                <strong>Proyecto:</strong> @_projectName
            </div>
        </div>
    }
    else if (_hasProjectsLoaded)
    {
        <div class="alert alert-warning d-flex align-items-center gap-2 mb-4">
            <i class="bi bi-exclamation-triangle fs-5"></i>
            <span>No tienes proyectos activos. Un miembro del equipo asignará tu ticket.</span>
        </div>
    }

    <EditForm Model="_ticketDto" OnValidSubmit="HandleSubmit">
        <DataAnnotationsValidator />
        <ValidationSummary class="alert alert-danger" />

        <div class="row">
            <div class="col-md-12">
                <div class="mb-3">
                    <label for="Title" class="form-label fw-bold small">Título *</label>
                    <InputText id="Title" class="form-control"
                               placeholder="Ej: No puedo acceder al sistema de facturación"
                               @bind-Value="_ticketDto.Title" />
                    <ValidationMessage For="@(() => _ticketDto.Title)" />
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-12">
                <div class="mb-3">
                    <label for="Description" class="form-label fw-bold small">Descripción *</label>
                    <InputTextArea id="Description" class="form-control" rows="5"
                                   placeholder="Describe detalladamente el problema o solicitud. Incluye cuándo ocurrió, qué estabas haciendo y cualquier mensaje de error que hayas visto..."
                                   @bind-Value="_ticketDto.Description" />
                    <ValidationMessage For="@(() => _ticketDto.Description)" />
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-end gap-2 mt-4">
            <button type="button" class="btn btn-secondary" @onclick="Cancel">Cancelar</button>
            <button type="submit" class="btn btn-primary" disabled="@_isSaving">
                @if (_isSaving)
                {
                    <span class="spinner-border spinner-border-sm me-2"></span>
                }
                <i class="bi bi-send"></i> Enviar Solicitud
            </button>
        </div>

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="alert alert-danger mt-3">@_errorMessage</div>
        }
    </EditForm>
</section>

@code {
    // Parámetros recibidos desde TicketsIndex
    [Parameter] public string? ClientEmail { get; set; }
    [Parameter] public int? ClientId { get; set; }
    [Parameter] public List<ProjectDetailDto>? Projects { get; set; }

    private TicketDto _ticketDto = new()
    {
        Status = "Abierto",
        Priority = "Media",
        ProjectId = null,
        ServiceId = null
    };

    private bool _isSaving = false;
    private string? _errorMessage;
    private List<ProjectDetailDto>? _projects;
    private bool _hasProjectsLoaded = false;
    private string _projectName = "";

    protected override void OnParametersSet()
    {
        _projects = Projects;

        // Solo asignar automáticamente si hay EXACTAMENTE 1 proyecto
        // Si tiene 2+ proyectos, el admin completará la info después
        if (_projects != null && _projects.Count == 1)
        {
            _ticketDto.ProjectId = _projects[0].Id;
            _projectName = _projects[0].Name;
        }

        _hasProjectsLoaded = true;
    }

    private async Task HandleSubmit()
    {
        _isSaving = true;
        _errorMessage = null;
        StateHasChanged();
        try
        {
            var result = await TicketApiService.CreateTicketAsync(_ticketDto);
            if (result.Success)
            {
                NotificationService.Notify(new NotificationMessage
                {
                    Severity = NotificationSeverity.Success,
                    Summary = "Solicitud enviada",
                    Detail = "Tu ticket ha sido creado. Nuestro equipo lo revisará y te notificará sobre su avance.",
                    Duration = 5000
                });
                DialogService.Close(true);
            }
            else
            {
                _errorMessage = result.ErrorMessage ?? "No se pudo crear el ticket.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error al enviar la solicitud: {ex.Message}";
        }
        finally
        {
            _isSaving = false;
            StateHasChanged();
        }
    }

    private void Cancel() => DialogService.Close(false);
}