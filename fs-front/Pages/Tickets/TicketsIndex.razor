@page "/tickets"
@using fs_front.DTO
@using Microsoft.AspNetCore.Components.Authorization

@attribute [Authorize]

<PageTitle>Finesoft - Tickets</PageTitle>

@if (_checkingAccess)
{
    <div style="position:fixed;top:0;left:0;width:100vw;height:100vh;
        background:white;z-index:9999;
        display:flex;align-items:center;justify-content:center;">
        <div class="spinner-border text-primary" role="status"></div>
    </div>
}
else if (!_hasAccess)
{
    <div></div>
}
else
{
    <div class="fs-index-layout">
        <section class="fs-index-section">
            <TicketsHeader CanCreate="@_canCreate"
                           CanViewAll="@_canViewAll"
                           IsLoading="@_loadingPermissions"
                           CurrentRole="@_currentRole"
                           OnCreate="ShowCreateModal" />

            @if (_stats != null)
            {
                <StatGrid>
                    <StatCard Title="Abiertos" Value="@_stats.Open.ToString()" Accent="StatCard.StatAccent.Primary" IconClass="bi bi-inbox" />
                    <StatCard Title="En Progreso" Value="@_stats.InProgress.ToString()" Accent="StatCard.StatAccent.Info" IconClass="bi bi-clock-history" />
                    <StatCard Title="En Revisión" Value="@_stats.InReview.ToString()" Accent="StatCard.StatAccent.Info" IconClass="bi bi-search" />
                    <StatCard Title="Cerrados" Value="@_stats.Closed.ToString()" Accent="StatCard.StatAccent.Success" IconClass="bi bi-check-circle" />
                </StatGrid>
            }
        </section>

        <section class="fs-index-section">
            <TicketsFilterBar SearchValue="@_searchText"
                              StatusFilter="@_statusFilter"
                              PriorityFilter="@_priorityFilter"
                              SearchValueChanged="OnSearchChanged"
                              StatusFilterChanged="OnStatusChanged"
                              PriorityFilterChanged="OnPriorityChanged"
                              OnClear="ClearFilters" />
        </section>

        <section class="fs-index-section">
            <TicketsTable Items="_filteredTickets"
                          IsLoading="_isLoading"
                          CanViewAll="@_canViewAll"
                          CurrentRole="@_currentRole"
                          SortField="@_sortField"
                          SortDir="@_sortDir"
                          SortChanged="OnSortChanged"
                          OnViewDetails="ViewTicketDetails"
                          OnCompleteInfo="ShowCompleteInfoModal" />
        </section>

        @if (_totalPages > 0)
        {
            <section class="fs-index-section">
                <div class="pagination-wrapper d-flex justify-content-between align-items-center mt-3 flex-wrap gap-2">
                    <div class="d-flex align-items-center gap-2">
                        <span class="text-muted">Mostrar:</span>
                        <select class="form-select form-select-sm" style="width:auto;"
                                @bind="_pageSize" @bind:after="() => OnPageSizeChanged(_pageSize)">
                            <option value="10">10</option>
                            <option value="20">20</option>
                            <option value="50">50</option>
                            <option value="100">100</option>
                        </select>
                        <span class="text-muted">registros</span>
                    </div>

                    <nav>
                        <ul class="pagination pagination-sm mb-0">
                            <li class="page-item @(_currentPage == 1 ? "disabled" : "")">
                                <button class="page-link" @onclick="() => OnPageChanged(1)" disabled="@(_currentPage == 1)">««</button>
                            </li>
                            <li class="page-item @(_currentPage == 1 ? "disabled" : "")">
                                <button class="page-link" @onclick="() => OnPageChanged(_currentPage - 1)" disabled="@(_currentPage == 1)">«</button>
                            </li>

                            @for (int i = Math.Max(1, _currentPage - 2); i <= Math.Min(_totalPages, _currentPage + 2); i++)
                            {
                                var pageNum = i;
                                <li class="page-item @(_currentPage == pageNum ? "active" : "")">
                                    <button class="page-link" @onclick="() => OnPageChanged(pageNum)">@pageNum</button>
                                </li>
                            }

                            <li class="page-item @(_currentPage == _totalPages ? "disabled" : "")">
                                <button class="page-link" @onclick="() => OnPageChanged(_currentPage + 1)" disabled="@(_currentPage == _totalPages)">»</button>
                            </li>
                            <li class="page-item @(_currentPage == _totalPages ? "disabled" : "")">
                                <button class="page-link" @onclick="() => OnPageChanged(_totalPages)" disabled="@(_currentPage == _totalPages)">»»</button>
                            </li>
                        </ul>
                    </nav>

                    <div class="text-muted small">
                        Página @_currentPage de @_totalPages (@_totalCount total)
                    </div>
                </div>
            </section>
        }
    </div>
}

@inject ITicketApiService TicketApiService
@inject IProjectApiService ProjectApiService
@inject DialogService DialogService
@inject NotificationService NotificationService
@inject NavigationManager NavigationManager
@inject IPermissionService PermissionService

@code {
    private List<TicketDetailDto>? _tickets;
    private TicketStatsDto? _stats;
    private string _searchText = string.Empty;
    private string _statusFilter = string.Empty;
    private string _priorityFilter = string.Empty;
    private bool _isLoading = false;
    private bool _loadingPermissions = true;

    private CancellationTokenSource? _cts;

    // Paginación
    private int _currentPage = 1;
    private int _pageSize = 20;
    private int _totalCount = 0;
    private int _totalPages => _pageSize > 0 ? (int)Math.Ceiling(_totalCount / (double)_pageSize) : 0;

    // Acceso
    private bool _checkingAccess = true;
    private bool _hasAccess = false;
    private string? _currentUserId;
    private string? _currentRole;
    private int? _clientId;

    // Permisos
    private bool _canViewAll = false;
    private bool _canCreate = false;
    private bool _canEdit = false;
    private bool _canDelete = false;

    // Ordenamiento
    private string _sortField = "createdAt";
    private FsSortHeader.SortDirection _sortDir = FsSortHeader.SortDirection.Desc;

    private IEnumerable<TicketDetailDto> _filteredTickets =>
        _tickets ?? Enumerable.Empty<TicketDetailDto>();

    // ── Ciclo de vida ─────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        // Una sola llamada resuelve todos los permisos desde los claims del JWT
        var bundle = await PermissionService.GetPermissionBundleAsync();

        if (!bundle.CanView)
        {
            _checkingAccess = false;
            _hasAccess = false;
            NavigationManager.NavigateTo("/dashboard", forceLoad: true);
            return;
        }

        _currentUserId = bundle.UserId;
        _currentRole = bundle.Role;
        _clientId = bundle.ClientId;
        _canCreate = bundle.CanCreate;
        _canEdit = bundle.CanEdit;
        _canDelete = bundle.CanDelete;
        _canViewAll = bundle.CanViewAll;
        _hasAccess = true;
        _checkingAccess = false;
        _loadingPermissions = false;
        StateHasChanged(); // header ya muestra el título correcto

        await LoadData();
    }

    // ── Carga de datos (stats + tickets en paralelo) ──────────────────────────
    private async Task LoadData()
    {
        _cts?.Cancel();
        _cts?.Dispose();
        _cts = new CancellationTokenSource();
        var token = _cts.Token;

        if (_isLoading) return;

        _isLoading = true;
        StateHasChanged();

        try
        {
            var userId = _currentRole == "Cliente" ? _currentUserId : null;
            var statusParam = string.IsNullOrWhiteSpace(_statusFilter) ? null : _statusFilter;
            var priorityParam = string.IsNullOrWhiteSpace(_priorityFilter) ? null : _priorityFilter;
            var searchParam = string.IsNullOrWhiteSpace(_searchText) ? null : _searchText;
            var sortDesc = _sortDir == FsSortHeader.SortDirection.Desc;

            if (token.IsCancellationRequested) return;

            // Stats y tickets en paralelo
            var statsTask = TicketApiService.GetTicketStatsAsync(userId);
            var ticketsTask = TicketApiService.GetTicketsPaginatedAsync(
                status: statusParam,
                priority: priorityParam,
                userId: userId,
                page: _currentPage,
                pageSize: _pageSize,
                search: searchParam,
                sortField: _sortField,
                sortDescending: sortDesc
            );

            await Task.WhenAll(statsTask, ticketsTask);

            if (token.IsCancellationRequested) return;

            var pagedResult = ticketsTask.Result;
            if (pagedResult != null)
            {
                _tickets = pagedResult.Items;
                _totalCount = pagedResult.Total;
            }
            else
            {
                _tickets = new List<TicketDetailDto>();
                _totalCount = 0;
            }

            _stats = statsTask.Result;
        }
        catch (OperationCanceledException) { /* cancelado intencionalmente */ }
        catch (Exception ex)
        {
            Notify("Error", $"Error al cargar datos: {ex.Message}", NotificationSeverity.Error);
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    // ── Handlers de filtros ───────────────────────────────────────────────────
    private async Task OnSearchChanged(string value)
    {
        if (_searchText == value) return;
        _searchText = value;
        _currentPage = 1;
        await LoadData();
    }

    private async Task OnStatusChanged(string value)
    {
        if (_statusFilter == value) return;
        _statusFilter = value;
        _currentPage = 1;
        await LoadData();
    }

    private async Task OnPriorityChanged(string value)
    {
        if (_priorityFilter == value) return;
        _priorityFilter = value;
        _currentPage = 1;
        await LoadData();
    }

    private async void OnSortChanged((string field, FsSortHeader.SortDirection dir) s)
    {
        _sortField = s.field;
        _sortDir = s.dir;
        await LoadData();
    }

    // ── Paginación ────────────────────────────────────────────────────────────
    private async Task OnPageChanged(int page)
    {
        _currentPage = page;
        await LoadData();
    }

    private async Task OnPageSizeChanged(int newSize)
    {
        _pageSize = newSize;
        _currentPage = 1;
        await LoadData();
    }

    // ── Acciones ──────────────────────────────────────────────────────────────
    private async Task ShowCreateModal()
    {
        bool? result;
        var isCliente = _currentRole == "Cliente" || await IsClientByProjectsAsync();

        if (isCliente)
        {
            var clientEmail = await PermissionService.GetUserEmailAsync(); // usa caché
            var clientId = _clientId; // ya lo tenemos del bundle, sin HTTP

            List<ProjectDetailDto> projects = new();
            if (clientId.HasValue)
            {
                var projList = await ProjectApiService.GetProjectsByClientIdAsync(clientId.Value);
                if (projList != null) projects = projList;
            }
            else if (!string.IsNullOrEmpty(clientEmail))
            {
                var projList = await ProjectApiService.GetProjectsByUserEmailAsync(clientEmail);
                if (projList != null) projects = projList;
            }

            if (projects.Count == 0)
                Notify("Info", $"Cliente: {clientEmail}, ClientId: {clientId}, Proyectos: 0", NotificationSeverity.Info);

            var parameters = new Dictionary<string, object>
            {
                { "ClientEmail", clientEmail ?? string.Empty },
                { "ClientId",   clientId },
                { "Projects",   projects }
            };

            result = await DialogService.OpenAsync<TicketFormCliente>("Crear Ticket",
                parameters,
                new DialogOptions { Width = "600px", Resizable = false, Draggable = false });
        }
        else
        {
            result = await DialogService.OpenAsync<TicketForm>("Crear Ticket",
                options: new DialogOptions { Width = "800px", Resizable = false, Draggable = false });
        }

        if (result == true) await LoadData();
    }

    private async Task<bool> IsClientByProjectsAsync()
    {
        var clientEmail = await PermissionService.GetUserEmailAsync(); // usa caché
        if (string.IsNullOrEmpty(clientEmail)) return false;
        var projects = await ProjectApiService.GetProjectsByUserEmailAsync(clientEmail);
        return projects != null && projects.Count > 0;
    }

    private void ViewTicketDetails(int ticketId) =>
        NavigationManager.NavigateTo($"/tickets/{ticketId}");

    private async Task ShowCompleteInfoModal(int ticketId)
    {
        var result = await DialogService.OpenAsync<CompleteTicketInfo>("Completar información",
            new Dictionary<string, object> { { "TicketId", ticketId } },
            new DialogOptions { Width = "500px", Resizable = false });

        if (result == true) await LoadData();
    }

    private async Task ClearFilters()
    {
        _searchText = string.Empty;
        _statusFilter = string.Empty;
        _priorityFilter = string.Empty;
        await LoadData();
    }

    private void Notify(string title, string message, NotificationSeverity severity) =>
        NotificationService.Notify(new NotificationMessage
        {
            Severity = severity,
            Summary = title,
            Detail = message,
            Duration = 4000
        });
}
